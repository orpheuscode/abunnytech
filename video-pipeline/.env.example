# TwelveLabs (analyze.py)
TWELVELABS_API_KEY=

# --- Gemini Developer API (default) ---
# GEMINI_API_KEY=your-ai-studio-key

# --- Vertex AI instead ---
# Set this to route all GenAI calls (Veo + Gemini) through Vertex:
GOOGLE_GENAI_USE_VERTEXAI=true

# Option A: Vertex with API key — you MUST also set the GCP project (Veo model path):
GEMINI_API_KEY=charming-bolt-492406-b4
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Option B: Vertex with Application Default Credentials (omit GEMINI_API_KEY)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional: override model IDs if Vertex names differ from AI Studio
# VEO_MODEL=veo-3.1-fast-generate-preview
# GEMINI_MODEL=gemini-3-flash-preview
