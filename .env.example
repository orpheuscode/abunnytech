# === AI Provider Keys (optional for dry-run demo) ===
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# === Social Platform Credentials (optional — only needed for live posting) ===
TIKTOK_SESSION_ID=
INSTAGRAM_SESSION_ID=
YOUTUBE_API_KEY=

# === Feature Flags ===
FEATURE_STAGE5_MONETIZE=false
DRY_RUN=true
KILL_SWITCH=false

# === Orchestrator ===
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./abunnytech.db
HACKATHON_PIPELINE_DB_PATH=data/hackathon_pipelines.sqlite3

# === Control Plane ===
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000
HACKATHON_LOOP_INTERVAL_SECONDS=300
HACKATHON_LOOP_MAX_CYCLES=
HACKATHON_NICHE_QUERY=dropship
HACKATHON_DEFAULT_CAPTION=Auto-generated UGC
HACKATHON_PRODUCT_IMAGE_PATH=data/reference_assets/product_reference.png
HACKATHON_AVATAR_IMAGE_PATH=data/reference_assets/avatar_reference.png
HACKATHON_MEDIA_PATH=output/hackathon_videos/generated_reel.mp4
HACKATHON_LOOP_WORKDIR=data/loop_runner

# === Dashboard ===
DASHBOARD_PORT=8501
