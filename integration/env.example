# Copy to the repository root as `.env` for the FastAPI app (see pipeline_core.settings).
# Copy or merge into your shell when running the debug dashboard only.

# --- FastAPI / pipeline_core (prefix PIPELINE_)
PIPELINE_DATABASE_URL=sqlite:///./pipeline.db
PIPELINE_ARTIFACTS_DIR=./artifacts
PIPELINE_DRY_RUN=false
PIPELINE_FEATURE_STAGE5_ENABLED=false
PIPELINE_DISCLOSURE_DEMO=true

# --- Debug dashboard & HTTP clients (no prefix; load manually or use dotenv)
PIPELINE_API_BASE=http://127.0.0.1:8000
